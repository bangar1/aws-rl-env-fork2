# ============================================================================
# AWS RL Environment — Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# LLM Inference (used by inference.py)
# ---------------------------------------------------------------------------

# API endpoint for the LLM (OpenAI-compatible)
# Base URL of the LLM which is getting trained. Defaults to HuggingFace's Inference API if not set.
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier
# Model Name which is getting trained. Defaults to Qwen/Qwen2.5-72B-Instruct if not set.
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct


# API key (set one of these MANDATORY) - either HF_TOKEN for HuggingFace or API_KEY for OpenAI. If both are set, API_KEY is used.
HF_TOKEN=
API_KEY=

# Inference parameters

# Maximum number of steps per episode. Defaults to 15 if not set.
MAX_STEPS=15
# Temperature for sampling (0.0 = greedy, 1.0 = more random). Defaults to 0.7 if not set.
TEMPERATURE=0.7
# Maximum number of tokens to generate in the LLM response. Defaults to 512 if not set.
MAX_TOKENS=512

# Stopping criteria for the LLM Training Loop
# Runs until reward convergence is detected at expert tier,
#   or MAX_EPISODES is reached. If the task is not complete the curriculum
#   re-prioritises it (weakness gets higher priority), so the agent will
#   retry weak tasks automatically.

# Maximum number of episodes to run during training. Defaults to 100 if not set.
MAX_EPISODES=100

# Episodes for plateau check (default: 10). Defaults to 10 if not set.
CONVERGENCE_WINDOW=10
# Minimum improvement threshold (default: 0.01). Defaults to 0.01 if not set.
CONVERGENCE_EPSILON=0.01
# Consecutive plateau checks (default: 2). Defaults to 2 if not set.
CONVERGENCE_PATIENCE=2

# ---------------------------------------------------------------------------
# Environment Connection
# ---------------------------------------------------------------------------

# If both SERVER_URL and LOCAL_IMAGE_NAME are set, the client prioritizes LOCAL_IMAGE_NAME.
# Setting one of these is required for the client to connect to the environment.

# Remote server URL (e.g. HuggingFace Space endpoint)
# If SERVER_URL is set and LOCAL_IMAGE_NAME is unset, the client connects here.
SERVER_URL=https://huggingface.co/spaces/Sizzing/aws_rl_env

# Docker image name (used by from_docker_image() in inference.py)
# Unset this to use SERVER_URL instead.
LOCAL_IMAGE_NAME=aws-rl-env:latest

# Benchmark name for logging
BENCHMARK=aws_rl_env

# ---------------------------------------------------------------------------
# AWS Infrastructure (AWS emulator — used inside the Docker container)
# ---------------------------------------------------------------------------

# AWS Infrastructure endpoint (default: http://localhost:4566)
AWS_INFRA_URL=http://localhost:4566

# AWS credentials for aws_infra (default: test/test)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Enable the OpenEnv web interface
ENABLE_WEB_INTERFACE=true

# Set to 1 for live reload during development
DEV_MODE=1
